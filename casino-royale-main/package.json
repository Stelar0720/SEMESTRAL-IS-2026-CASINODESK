{
  "name": "casino-desk-prototype",
  "private": true,
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "dev": "npm --workspace apps/frontend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:api": "dotnet run --project .\\apps\\backend\\CasinoDesk.Api --urls http://localhost:5067",
    "build": "npm --workspace apps/frontend run build",
    "build:api": "dotnet build .\\apps\\backend\\CasinoDesk.Api -c Debug",
    "preview": "npm --workspace apps/frontend run preview",
    "test": "npm --workspace apps/frontend run test",
    "test:coverage": "npm --workspace apps/frontend run test:coverage",
    "test:e2e": "node scripts/e2e-smoke.mjs"
  }
}
